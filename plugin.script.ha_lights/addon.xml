<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.script.ha_lights"
       name="Home Assistant Lights"
       version="1.0.0"
       provider-name="Hornet49">
  <requires>
    <import addon="xbmc.python" version="3.0.0"/>
  </requires>

  <!-- Point d'entrée du menu (lancé manuellement) -->
  <extension point="xbmc.python.script"
             library="default.py">
    <provides>executable</provides>
  </extension>

  <!-- Service d'arrière-plan (lancé automatiquement au démarrage de Kodi) -->
  <extension point="xbmc.service"
             library="service.py"
             start="login"/>

  <extension point="xbmc.addon.metadata">
    <summary lang="fr">Contrôle les lumières Home Assistant</summary>
    <description lang="fr">
      Allume et éteint les lumières de votre maison via Home Assistant directement depuis Kodi.
      Pilotage automatique : extinction au lancement d'un film, variation en pause, rallumage avant la fin.
    </description>
    <disclaimer lang="fr">Nécessite un serveur Home Assistant avec un token d'accès longue durée.</disclaimer>
    <platform>all</platform>
  </extension>
</addon>
